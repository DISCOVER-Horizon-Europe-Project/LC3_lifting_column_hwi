<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="lc3_column">

    <xacro:arg name="use_mock_hardware" default="false"/>
    <xacro:arg name="simulation" default="false"/>

    <!-- Base link-->
    <link name="base_link">
        <visual>
            <geometry>
                <box size="0.2 0.2 0.02"/>
            </geometry>
            <origin xyz="0 0 0.01" rpy="0 0 0"/>
            <material name="light_gray">
                <color rgba="0.7 0.7 0.7 1"/>
            </material>
        </visual>
        <visual>
            <geometry>
                <box size="0.164 0.164 0.82"/>
            </geometry>
            <origin xyz="0 0 0.43" rpy="0 0 0"/>
            <material name="light_gray">
                <color rgba="0.7 0.7 0.7 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <box size="0.164 0.164 0.84"/>
            </geometry>
            <origin xyz="0 0 0.42" rpy="0 0 0"/>
        </collision>
        <inertial>
            <mass value="10.0"/>
            <inertia ixx="0.2" ixy="0.0" ixz="0.0" iyy="0.2" iyz="0.0" izz="0.03"/>
        </inertial>
    </link>

    <!-- Column link -->
    <link name="column_link">
        <visual>
            <geometry>
                <box size="0.148 0.148 0.80"/>
            </geometry>
            <origin xyz="0 0 0.40" rpy="0 0 0"/>
            <material name="light_gray">
                <color rgba="0.7 0.7 0.7 1"/>
            </material>
        </visual>
        <visual>
            <geometry>
                <box size="0.129 0.129 0.84"/>
            </geometry>
            <origin xyz="0 0 0.82" rpy="0 0 0"/>
            <material name="light_gray">
                <color rgba="0.7 0.7 0.7 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <box size="0.148 0.148 1.24"/>
            </geometry>
            <origin xyz="0 0 0.62" rpy="0 0 0"/>
        </collision>
        <inertial>
            <mass value="10.0"/>
            <origin xyz="0 0 0.62" rpy="0 0 0"/>
            <inertia ixx="0.12" ixy="0.0" ixz="0.0" iyy="0.12" iyz="0.0" izz="0.02"/>
        </inertial>
    </link>

    <!-- Prismatic joint for column -->
    <joint name="column_joint" type="prismatic">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="column_link"/>
        <axis xyz="0 0 1"/>
        <limit lower="0.0" upper="0.9" effort="1000.0" velocity="0.1"/>
        <dynamics damping="10.0" friction="1.0"/>
    </joint>

    <!-- ros2_control hardware interface -->
    <ros2_control name="lc3_column_controller" type="system">
        <xacro:unless value="$(arg simulation)">
            <xacro:unless value="$(arg use_mock_hardware)">
                <hardware>
                    <plugin>lc3_hw_interface/LC3HardwareInterface</plugin>
                    <param name="column_name">column_joint</param>
                </hardware>
            </xacro:unless>
            <xacro:if value="$(arg use_mock_hardware)">
                <hardware>
                    <plugin>mock_components/GenericSystem</plugin>
                    <param name="calculate_dynamics">true</param>
                </hardware>
            </xacro:if>
        </xacro:unless>

        <xacro:if value="$(arg simulation)">
            <hardware>
                <plugin>gazebo_ros2_control/GazeboSystem</plugin>
            </hardware>
        </xacro:if>

        <joint name="column_joint">
            <command_interface name="position"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
    </ros2_control>

</robot>
